<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IFSC Bank Inquiry - RazorPay API</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body>
    <div class="background-gradient"></div>
    
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">
                <i class="fas fa-university me-2"></i>IFSC Inquiry
            </a>
        </div>
    </nav>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg border-0 rounded-lg overflow-hidden">
                    <div class="card-header bg-gradient text-white py-4">
                        <h1 class="mb-0 text-center">
                            <i class="fas fa-search me-2"></i>Bank IFSC Lookup
                        </h1>
                    </div>
                    
                    <div class="card-body p-5">
                        <form action="/IFSC" method="post" class="ifsc-form">
                            <div class="input-group input-group-lg mb-3">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-code text-primary"></i>
                                </span>
                                <input 
                                    type="text" 
                                    name="ifsc" 
                                    class="form-control border-0 py-2" 
                                    placeholder="Enter IFSC Code (e.g., SBIN0001234)" 
                                    required
                                    autocomplete="off">
                                <button class="btn btn-primary btn-lg" type="submit">
                                    <i class="fas fa-search me-2"></i>Search
                                </button>
                            </div>
                            <small class="text-muted d-block text-center">
                                <i class="fas fa-info-circle me-1"></i>IFSC codes are 11-character alphanumeric codes
                            </small>
                        </form>

                        <% if (locals.data) { %>
                            <div class="results-section mt-5 pt-4 border-top">
                                <h3 class="mb-4 text-center text-success">
                                    <i class="fas fa-check-circle me-2"></i>Bank Information
                                </h3>
                                
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="info-card">
                                            <div class="info-label">
                                                <i class="fas fa-building text-primary"></i> Bank Name
                                            </div>
                                            <div class="info-value"><%= Bank %></div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="info-card">
                                            <div class="info-label">
                                                <i class="fas fa-code text-primary"></i> Branch Name
                                            </div>
                                            <div class="info-value"><%= Branch %></div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="info-card">
                                            <div class="info-label">
                                                <i class="fas fa-map-marker-alt text-primary"></i> Centre
                                            </div>
                                            <div class="info-value"><%= Centre %></div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="info-card">
                                            <div class="info-label">
                                                <i class="fas fa-map text-primary"></i> District
                                            </div>
                                            <div class="info-value"><%= District %></div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="info-card">
                                            <div class="info-label">
                                                <i class="fas fa-flag text-primary"></i> State
                                            </div>
                                            <div class="info-value"><%= State %></div>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-6">
                                        <div class="info-card">
                                            <div class="info-label">
                                                <i class="fas fa-address-card text-primary"></i> Address
                                            </div>
                                            <div class="info-value"><%= Address %></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center py-4 text-muted mt-5">
        <p class="mb-0" style="color: white;">
            <i class="fas fa-lock me-1"></i>Powered by Razorpay IFSC API
        </p>
    </footer>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="/styles/main.js"></script>
</body>
</html>